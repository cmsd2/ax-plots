/* Custom initial points and time range */
ax_draw2d(
  initial_points=[[0.5,0.5],[2,2],[3,1]],
  t_range=[0,20], dt=0.01,
  ax_streamline(x*(1-y), y*(x-1), x, 0, 4, y, 0, 4),
  title="Lotka-Volterra"
)$


