 -- Function: ax_draw2d ([ARGS])
     Draw 2D interactive plots using Plotly.js.  Accepts Maxima draw
     package objects and Aximar-specific objects, rendering them as
     interactive charts with pan, zoom, and hover.

* Menu:

     * Supported Objects::
     * Examples: Examples 2.
     * Style Options: Style Options 2.
     * Layout Options: Layout Options 2.


File: ax-plots.info,  Node: Supported Objects,  Next: Examples 2,  Prev: Layout Options,  Up: Examples

1.2.1.3 Supported Objects
.........................

*Draw package objects:*

Object               Syntax               Description
---------------------------------------------------------------------------
‘explicit’           ‘explicit(expr,      A curve y=f(x)
                     var, lo, hi)’
‘parametric’         ‘parametric(x(t),    A parametric curve
                     y(t), t, tlo,
                     thi)’
‘points’             ‘points([[x1,y1],[x2,y2],...])’Scatter points
‘implicit’           ‘implicit(eqn, x,    An implicit curve f(x,y)=0
                     xlo, xhi, y, ylo,
                     yhi)’

*Aximar objects:*

Object               Syntax               Description
---------------------------------------------------------------------------
‘ax_contour’         ‘ax_contour(expr,    Filled contour plot
                     x, xlo, xhi, y,
                     ylo, yhi)’
‘ax_heatmap’         ‘ax_heatmap(matrix)’ Heatmap
                     or
                     ‘ax_heatmap(expr,
                     x, xlo, xhi, y,
                     ylo, yhi)’
‘ax_bar’             ‘ax_bar(categories,  Bar chart
                     values)’ or
                     ‘ax_bar(values)’
‘ax_histogram’       ‘ax_histogram(data)’ Histogram
‘ax_vector_field’    ‘ax_vector_field(Fx, 2D vector field
                     Fy, x, xlo, xhi,
                     y, ylo, yhi)’
‘ax_streamline’      ‘ax_streamline(Fx,   Streamline / phase portrait
                     Fy, x, xlo, xhi,     curves
                     y, ylo, yhi)’


File: ax-plots.info,  Node: Examples 2,  Next: Style Options 2,  Prev: Supported Objects,  Up: Examples

1.2.1.4 Examples
................

/* Explicit curves with styling */
ax_draw2d(
  color="red", explicit(x^2, x, -3, 3),
  color="blue", explicit(x^3, x, -2, 2)
)$

/* Filled contour */
ax_draw2d(
  ax_contour(sin(x)*cos(y), x, -%pi, %pi, y, -%pi, %pi),
  colorscale="Viridis", title="Contour Plot"
)$

/* Bar chart */
ax_draw2d(
  ax_bar(["Q1","Q2","Q3","Q4"], [100,150,120,180]),
  title="Quarterly Sales"
)$

/* Histogram */
ax_draw2d(
  ax_histogram(makelist(random(100)/10.0, i, 1, 500)),
  nbins=20, title="Distribution"
)$

/* Phase portrait: vector field + streamlines */
ax_draw2d(
  color="#cccccc", ax_vector_field(-y, x, x, -3, 3, y, -3, 3),
  color="red", ax_streamline(-y, x, x, -3, 3, y, -3, 3),
  aspect_ratio=true, title="Phase Portrait"
)$

/* Streamlines with custom initial conditions */
ax_draw2d(
  initial_points=[[1,0],[0,1],[-1,0],[0,-1]],
  t_range=[0,8],
  ax_streamline(-y, x, x, -3, 3, y, -3, 3),
  aspect_ratio=true
)$


